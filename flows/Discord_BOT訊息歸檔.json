{
  "name": "Discord BOT 訊息歸檔",
  "nodes": [
    {
      "id": "trigger",
      "name": "手動觸發",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        -900,
