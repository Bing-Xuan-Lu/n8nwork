N8N_API_URL=http://localhost:5678/api/v1
N8N_API_KEY=your_n8n_api_key_here
GOOGLE_AUTH_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_AUTH_CLIENT_SECRET=your_google_client_secret

# Discord Bot
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_ARCHIVE_CHANNEL=your_discord_channel_id

# MySQL (discord_bot_db on pure_php_db container)
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_root_password
MYSQL_DB=discord_bot_db
